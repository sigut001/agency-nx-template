rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner() {
      return isAuthenticated() && (
        request.auth.token.role == 'owner' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner'
      );
    }
    
    function isEditor() {
      return isAuthenticated() && (
        request.auth.token.role == 'editor' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor'
      );
    }
    
    function isOwnerOrEditor() {
      return isOwner() || isEditor();
    }
    
    // Users Collection - Only Owners can manage users
    match /users/{userId} {
      // Anyone authenticated can read their own profile
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // Owners can read all user profiles
      allow read: if isOwner();
      
      // Owners can create and update user profiles
      allow create, update: if isOwner();
      
      // Users can update their own profile (but not change role)
      allow update: if isAuthenticated() && 
                       request.auth.uid == userId && 
                       request.resource.data.role == resource.data.role;
      
      // Only owners can delete users
      allow delete: if isOwner();
    }
    
    // Pages Collection - Owners and Editors can manage content
    match /pages/{pageId} {
      // Public read access for SSG/prerendering
      allow read: if true;
      
      // Owners and Editors can create/update pages
      allow create, update: if isOwnerOrEditor();
      
      // Only Owners can delete pages
      allow delete: if isOwner();
      
      // History Sub-Collection
      match /history/{historyId} {
        // Public read for content recovery
        allow read: if true;
        
        // Owners and Editors can create history entries
        allow create: if isOwnerOrEditor();
        
        // Only Owners can delete history
        allow delete: if isOwner();
      }
    }
    
    // Config Collection - System configuration
    match /config/{configId} {
      // Public read for navigation, etc.
      allow read: if true;
      
      // Only Owners can update config
      allow update: if isOwner();
      
      // Prevent deletion of config documents
      allow delete: if false;
    }

    // Validation Test Collection
    match /_validation_test/{docId} {
      allow read, write: if isOwner();
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
